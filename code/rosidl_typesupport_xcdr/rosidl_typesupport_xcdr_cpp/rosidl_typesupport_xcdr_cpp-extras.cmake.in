# copied from rosidl_typesupport_xcdr_cpp/rosidl_typesupport_xcdr_cpp-extras.cmake

find_package(ament_cmake_core QUIET REQUIRED)
ament_register_extension(
  "rosidl_generate_idl_interfaces"
  "rosidl_typesupport_xcdr_cpp"
  "rosidl_typesupport_xcdr_cpp_generate_interfaces.cmake")

set(rosidl_typesupport_xcdr_cpp_BIN
  "${rosidl_typesupport_xcdr_cpp_DIR}/../../../lib/rosidl_typesupport_xcdr_cpp/rosidl_typesupport_xcdr_cpp")
normalize_path(rosidl_typesupport_xcdr_cpp_BIN
  "${rosidl_typesupport_xcdr_cpp_BIN}")

set(rosidl_typesupport_xcdr_cpp_GENERATOR_FILES
  "${rosidl_typesupport_xcdr_cpp_DIR}/../../../@PYTHON_INSTALL_DIR@/rosidl_typesupport_xcdr_cpp/__init__.py")
normalize_path(rosidl_typesupport_xcdr_cpp_GENERATOR_FILES
  "${rosidl_typesupport_xcdr_cpp_GENERATOR_FILES}")

set(rosidl_typesupport_xcdr_cpp_TEMPLATE_DIR
  "${rosidl_typesupport_xcdr_cpp_DIR}/../resource")
normalize_path(rosidl_typesupport_xcdr_cpp_TEMPLATE_DIR
  "${rosidl_typesupport_xcdr_cpp_TEMPLATE_DIR}")
