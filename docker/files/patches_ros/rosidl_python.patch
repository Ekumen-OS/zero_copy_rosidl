+"""Tests for rosidl_generator_py.experimental helper functions."""
+
+import pytest
+
+from rosidl_parser.definition import (
+    Array,
+    BasicType,
+    BoundedSequence,
+    BoundedString,
+    BoundedWString,
+    NamespacedType,
+    String,
+    UnboundedSequence,
+    UnboundedString,
+    UnboundedWString,
+)
+
+from rosidl_generator_py.experimental import (
+    BASIC_TYPE_TO_DTYPE,
+    experimental_constraint_type,
+    experimental_msg_type,
+)
+
+
+# ---------------------------------------------------------------------------
+# BASIC_TYPE_TO_DTYPE mapping
+# ---------------------------------------------------------------------------
+
+class TestBasicTypeToDtype:
+
+    def test_all_basic_types_mapped(self):
+        expected_keys = {
+            'boolean', 'octet', 'char', 'wchar',
+            'float', 'double', 'long double',
+            'uint8', 'int8', 'uint16', 'int16',
+            'uint32', 'int32', 'uint64', 'int64',
+        }
+        assert set(BASIC_TYPE_TO_DTYPE.keys()) == expected_keys
+
+    def test_values_are_dtype_strings(self):
+        for key, value in BASIC_TYPE_TO_DTYPE.items():
+            assert value.startswith('Dtype.'), f'{key} -> {value}'
+
+
+# ---------------------------------------------------------------------------
+# experimental_msg_type
+# ---------------------------------------------------------------------------
+
+class TestExperimentalMsgType:
+
+    @pytest.mark.parametrize('typename, expected_dtype', [
+        ('boolean', 'Dtype.BOOL'),
+        ('int32', 'Dtype.INT32'),
+        ('float', 'Dtype.FLOAT32'),
+        ('double', 'Dtype.FLOAT64'),
+        ('uint8', 'Dtype.UINT8'),
+        ('char', 'Dtype.CHAR'),
+    ])
+    def test_basic_type_becomes_scalar(self, typename, expected_dtype):
+        bt = BasicType(typename)
+        result = experimental_msg_type(bt)
+        assert result == f'Scalar({expected_dtype})'
+
+    def test_unbounded_string(self):
+        result = experimental_msg_type(UnboundedString())
+        assert result == 'String()'
+
+    def test_bounded_string(self):
+        result = experimental_msg_type(BoundedString(128))
+        assert result == 'BoundedString(128)'
+
+    def test_unbounded_wstring(self):
+        result = experimental_msg_type(UnboundedWString())
+        assert result == 'WString()'
+
+    def test_bounded_wstring(self):
+        result = experimental_msg_type(BoundedWString(64))
+        assert result == 'BoundedWString(64)'
+
+    def test_array_of_basic_type(self):
+        result = experimental_msg_type(Array(BasicType('int32'), 10))
+        assert result == 'Array(Dtype.INT32, 10)'
+
+    def test_array_of_namespaced_type(self):
+        nt = NamespacedType(['pkg', 'msg'], 'Sub')
+        result = experimental_msg_type(Array(nt, 3))
+        assert 'Array(Sub, 3' in result
+        assert 'MessageInitialization.SKIP' in result
+
+    def test_bounded_sequence_of_basic(self):
+        result = experimental_msg_type(BoundedSequence(BasicType('float'), 50))
+        assert result == 'BoundedSequence(Dtype.FLOAT32, 50)'
+
+    def test_unbounded_sequence_of_basic(self):
+        result = experimental_msg_type(UnboundedSequence(BasicType('int64')))
+        assert result == 'Sequence(Dtype.INT64)'
+
+    def test_unbounded_sequence_of_string(self):
+        result = experimental_msg_type(UnboundedSequence(UnboundedString()))
+        assert result == 'Sequence(String)'
+
+    def test_unbounded_sequence_of_namespaced(self):
+        nt = NamespacedType(['pkg', 'msg'], 'Sub')
+        result = experimental_msg_type(UnboundedSequence(nt))
+        assert result == 'Sequence(Sub)'
+
+    def test_array_of_unbounded_string(self):
+        result = experimental_msg_type(Array(UnboundedString(), 5))
+        assert 'Array(String, 5' in result
+
+    def test_array_of_bounded_string(self):
+        result = experimental_msg_type(Array(BoundedString(32), 3))
+        assert 'Array(BoundedString, 3' in result
+        assert 'BoundedString(32)' in result
+
+
+# ---------------------------------------------------------------------------
+# experimental_constraint_type
+# ---------------------------------------------------------------------------
+
+class TestExperimentalConstraintType:
+
+    def test_basic_type_no_constraint(self):
+        assert experimental_constraint_type(BasicType('int32')) is None
+
+    def test_bounded_string_no_constraint(self):
+        assert experimental_constraint_type(BoundedString(128)) is None
+
+    def test_unbounded_string_has_string_constraint(self):
+        assert experimental_constraint_type(UnboundedString()) == 'StringConstraint'
+
+    def test_unbounded_wstring_has_string_constraint(self):
+        assert experimental_constraint_type(UnboundedWString()) == 'StringConstraint'
+
+    def test_bounded_wstring_no_constraint(self):
+        assert experimental_constraint_type(BoundedWString(64)) is None
+
+    def test_namespaced_type_has_constraints(self):
+        nt = NamespacedType(['pkg', 'msg'], 'Sub')
+        assert experimental_constraint_type(nt) == 'Sub.Constraints'
+
+    def test_array_of_basic_no_constraint(self):
+        assert experimental_constraint_type(Array(BasicType('int32'), 10)) is None
+
+    def test_array_of_unbounded_string_has_constraint(self):
+        assert experimental_constraint_type(
+            Array(UnboundedString(), 5)) == 'StringConstraint'
+
+    def test_array_of_namespaced_has_constraint(self):
+        nt = NamespacedType(['pkg', 'msg'], 'Sub')
+        assert experimental_constraint_type(Array(nt, 3)) == 'Sub.Constraints'
+
+    def test_bounded_sequence_no_constraint(self):
+        assert experimental_constraint_type(
+            BoundedSequence(BasicType('int32'), 100)) is None
+
+    def test_unbounded_sequence_has_constraint(self):
+        assert experimental_constraint_type(
+            UnboundedSequence(BasicType('int32'))) == 'SequenceConstraint'
+
+    def test_unbounded_sequence_of_string_has_constraint(self):
+        assert experimental_constraint_type(
+            UnboundedSequence(UnboundedString())) == 'SequenceConstraint'
diff --git a/rosidl_generator_py/test/test_experimental_interfaces.py b/rosidl_generator_py/test/test_experimental_interfaces.py
new file mode 100644
index 0000000..79e9aed
--- /dev/null
+++ b/rosidl_generator_py/test/test_experimental_interfaces.py
@@ -0,0 +1,292 @@
+# Copyright 2026 Ekumen, Inc.
+#
+# Licensed under the Apache License, Version 2.0 (the "License");
+# you may not use this file except in compliance with the License.
+# You may obtain a copy of the License at
+#
+#     http://www.apache.org/licenses/LICENSE-2.0
+#
+# Unless required by applicable law or agreed to in writing, software
+# distributed under the License is distributed on an "AS IS" BASIS,
+# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+# See the License for the specific language governing permissions and
+# limitations under the License.
+
+"""Tests for generated experimental Python message classes.
+
+These tests verify that the experimental messages generated by
+rosidl_generator_py produce working classes backed by the experimental
+container types from rosidl_runtime_py.experimental.
+"""
+
+import pytest
+
+from rosidl_runtime_py.experimental import (
+    Array,
+    BoundedSequence,
+    BoundedString,
+    BoundedWString,
+    Dtype,
+    MessageInitialization,
+    Scalar,
+    Sequence,
+    SequenceConstraint,
+    String,
+    StringConstraint,
+    WString,
+)
+
+
+# Import generated experimental messages.
+# These are generated from the same IDL files as the standard messages
+# but under the experimental subpackage.
+from rosidl_generator_py.msg.experimental import BasicTypes
+from rosidl_generator_py.msg.experimental import Constants
+from rosidl_generator_py.msg.experimental import Defaults
+from rosidl_generator_py.msg.experimental import Strings
+from rosidl_generator_py.msg.experimental import WStrings
+from rosidl_generator_py.msg.experimental import Arrays
+from rosidl_generator_py.msg.experimental import UnboundedSequences
+from rosidl_generator_py.msg.experimental import BoundedSequences
+from rosidl_generator_py.msg.experimental import Nested
+
+
+# ---------------------------------------------------------------------------
+# BasicTypes
+# ---------------------------------------------------------------------------
+
+class TestBasicTypes:
+
+    def test_default_construction(self):
+        msg = BasicTypes()
+        # All scalar fields should be Scalar instances
+        assert isinstance(msg.bool_value, Scalar)
+        assert isinstance(msg.byte_value, Scalar)
+        assert isinstance(msg.char_value, Scalar)
+        assert isinstance(msg.float32_value, Scalar)
+        assert isinstance(msg.float64_value, Scalar)
+        assert isinstance(msg.int8_value, Scalar)
+        assert isinstance(msg.uint8_value, Scalar)
+        assert isinstance(msg.int16_value, Scalar)
+        assert isinstance(msg.uint16_value, Scalar)
+        assert isinstance(msg.int32_value, Scalar)
+        assert isinstance(msg.uint32_value, Scalar)
+        assert isinstance(msg.int64_value, Scalar)
+        assert isinstance(msg.uint64_value, Scalar)
+
+    def test_default_values_are_zero(self):
+        msg = BasicTypes()
+        assert msg.bool_value.value == False  # noqa: E712
+        assert msg.float32_value.value == 0.0
+        assert msg.int32_value.value == 0
+        assert msg.uint64_value.value == 0
+
+    def test_scalar_assignment(self):
+        msg = BasicTypes()
+        msg.int32_value.value = 42
+        assert msg.int32_value.value == 42
+
+    def test_equality(self):
+        a = BasicTypes()
+        b = BasicTypes()
+        assert a == b
+        a.int32_value.value = 99
+        assert a != b
+
+    def test_skip_initialization(self):
+        msg = BasicTypes(_init=MessageInitialization.SKIP)
+        # Should still be Scalar instances
+        assert isinstance(msg.int32_value, Scalar)
+
+    def test_constraints_class_exists(self):
+        c = BasicTypes.Constraints()
+        assert c == BasicTypes.Constraints()
+
+    def test_repr(self):
+        msg = BasicTypes()
+        r = repr(msg)
+        assert 'BasicTypes' in r
+
+
+# ---------------------------------------------------------------------------
+# Constants
+# ---------------------------------------------------------------------------
+
+class TestConstants:
+
+    def test_constants_accessible(self):
+        assert hasattr(Constants, 'BOOL_CONST')
+        assert Constants.BOOL_CONST is True
+        assert hasattr(Constants, 'INT32_CONST')
+        assert Constants.INT32_CONST == -30000
+        assert hasattr(Constants, 'FLOAT64_CONST')
+        assert abs(Constants.FLOAT64_CONST - 1.125) < 1e-6
+
+
+# ---------------------------------------------------------------------------
+# Strings
+# ---------------------------------------------------------------------------
+
+class TestStrings:
+
+    def test_string_fields(self):
+        msg = Strings()
+        assert isinstance(msg.string_value, String)
+        assert isinstance(msg.bounded_string_value, BoundedString)
+
+    def test_string_assign(self):
+        msg = Strings()
+        msg.string_value.assign('hello')
+        assert str(msg.string_value) == 'hello'
+
+    def test_equality(self):
+        a = Strings()
+        b = Strings()
+        assert a == b
+        a.string_value.assign('different')
+        assert a != b
+
+
+# ---------------------------------------------------------------------------
+# WStrings
+# ---------------------------------------------------------------------------
+
+class TestWStrings:
+
+    def test_wstring_fields(self):
+        msg = WStrings()
+        assert isinstance(msg.wstring_value, WString)
+        assert isinstance(msg.array_of_wstrings, Array)
+        assert isinstance(msg.bounded_sequence_of_wstrings, BoundedSequence)
+        assert isinstance(msg.unbounded_sequence_of_wstrings, Sequence)
+
+
+# ---------------------------------------------------------------------------
+# Arrays
+# ---------------------------------------------------------------------------
+
+class TestArrays:
+
+    def test_array_fields(self):
+        msg = Arrays()
+        # Primitive arrays should be Array instances
+        assert isinstance(msg.bool_values, Array)
+        assert isinstance(msg.int32_values, Array)
+        assert isinstance(msg.float32_values, Array)
+        assert isinstance(msg.string_values, Array)
+
+    def test_primitive_array_length(self):
+        msg = Arrays()
+        assert len(msg.bool_values) == 3
+        assert len(msg.int32_values) == 3
+        assert len(msg.float32_values) == 3
+
+    def test_array_element_access(self):
+        msg = Arrays()
+        msg.int32_values[0] = 42
+        assert msg.int32_values[0] == 42
+
+    def test_equality(self):
+        a = Arrays()
+        b = Arrays()
+        assert a == b
+
+
+# ---------------------------------------------------------------------------
+# UnboundedSequences
+# ---------------------------------------------------------------------------
+
+class TestUnboundedSequences:
+
+    def test_sequence_fields(self):
+        msg = UnboundedSequences()
+        assert isinstance(msg.bool_values, Sequence)
+        assert isinstance(msg.int32_values, Sequence)
+        assert isinstance(msg.string_values, Sequence)
+
+    def test_sequence_starts_empty(self):
+        msg = UnboundedSequences()
+        assert len(msg.bool_values) == 0
+        assert len(msg.int32_values) == 0
+
+    def test_sequence_append(self):
+        msg = UnboundedSequences()
+        msg.int32_values.append(42)
+        msg.int32_values.append(99)
+        assert len(msg.int32_values) == 2
+        assert msg.int32_values[0] == 42
+
+    def test_constraints_class(self):
+        c = UnboundedSequences.Constraints()
+        # Unbounded sequences should have SequenceConstraint fields
+        assert hasattr(c, 'bool_values')
+        assert isinstance(c.bool_values, SequenceConstraint)
+
+
+# ---------------------------------------------------------------------------
+# BoundedSequences
+# ---------------------------------------------------------------------------
+
+class TestBoundedSequences:
+
+    def test_bounded_sequence_fields(self):
+        msg = BoundedSequences()
+        assert isinstance(msg.bool_values, BoundedSequence)
+        assert isinstance(msg.int32_values, BoundedSequence)
+
+    def test_bounded_sequence_limit(self):
+        msg = BoundedSequences()
+        assert msg.bool_values.max_size == 3
+        assert msg.int32_values.max_size == 3
+
+
+# ---------------------------------------------------------------------------
+# Nested
+# ---------------------------------------------------------------------------
+
+class TestNested:
+
+    def test_nested_field(self):
+        msg = Nested()
+        assert isinstance(msg.basic_types_value, BasicTypes)
+
+    def test_nested_equality(self):
+        a = Nested()
+        b = Nested()
+        assert a == b
+        a.basic_types_value.int32_value.value = 42
+        assert a != b
+
+    def test_constraints(self):
+        c = Nested.Constraints()
+        assert hasattr(c, 'basic_types_value')
+
+
+# ---------------------------------------------------------------------------
+# Defaults
+# ---------------------------------------------------------------------------
+
+class TestDefaults:
+
+    def test_default_values_applied(self):
+        msg = Defaults()
+        # The Defaults message has fields with default annotations
+        assert msg.bool_value.value is True
+        assert msg.int8_value.value == -50
+        assert msg.uint8_value.value == 200
+        assert abs(msg.float32_value.value - 1.125) < 1e-5
+        assert abs(msg.float64_value.value - 1.125) < 1e-9
+
+    def test_defaults_only(self):
+        msg = Defaults(_init=MessageInitialization.DEFAULTS_ONLY)
+        assert isinstance(msg.bool_value, Scalar)
+        assert msg.bool_value.value is True
+
+    def test_zero_does_not_apply_defaults(self):
+        msg = Defaults(_init=MessageInitialization.ZERO)
+        # With ZERO, defaults should not be applied
+        assert isinstance(msg.bool_value, Scalar)
+
+    def test_skip(self):
+        msg = Defaults(_init=MessageInitialization.SKIP)
+        assert isinstance(msg.bool_value, Scalar)
diff --git a/rosidl_runtime_cpython/CMakeLists.txt b/rosidl_runtime_cpython/CMakeLists.txt
new file mode 100644
index 0000000..98f4424
--- /dev/null
+++ b/rosidl_runtime_cpython/CMakeLists.txt
@@ -0,0 +1,74 @@
+cmake_minimum_required(VERSION 3.20)
+
+project(rosidl_runtime_cpython)
+
+# Default to C11
+if(NOT CMAKE_C_STANDARD)
+  set(CMAKE_C_STANDARD 11)
+endif()
+
+if(CMAKE_COMPILER_IS_GNUCC OR CMAKE_C_COMPILER_ID MATCHES "Clang")
+  add_compile_options(-Wall -Wextra -Wpedantic)
+endif()
+
+find_package(ament_cmake REQUIRED)
+find_package(ament_cmake_python REQUIRED)
+find_package(rosidl_runtime_c REQUIRED)
+
+# Prefer the unversioned system Python (matches rclpy's approach).
+cmake_policy(SET CMP0094 NEW)
+set(Python3_FIND_UNVERSIONED_NAMES FIRST)
+find_package(Python3 REQUIRED COMPONENTS Interpreter Development)
+
+# ---------------------------------------------------------------------------
+# Pure Python package
+# ---------------------------------------------------------------------------
+ament_python_install_package(${PROJECT_NAME})
+
+# ---------------------------------------------------------------------------
+# C extension: rosidl_runtime_cpython._raw_buffer  (provides RawBuffer)
+# ---------------------------------------------------------------------------
+Python3_add_library(_raw_buffer MODULE src/raw_buffer.c)
+target_include_directories(_raw_buffer PRIVATE
+  "$<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/include>"
+  ${rosidl_runtime_c_INCLUDE_DIRS}
+)
+target_link_libraries(_raw_buffer PRIVATE
+  rosidl_runtime_c::rosidl_runtime_c
+)
+set_target_properties(_raw_buffer PROPERTIES
+  # Output into the rosidl_runtime_cpython/ subdirectory of the build space so that
+  # PYTHONPATH=${CMAKE_CURRENT_BINARY_DIR} resolves the submodule import
+  # `from rosidl_runtime_cpython._raw_buffer import RawBuffer` correctly.
+  LIBRARY_OUTPUT_DIRECTORY $<1:${CMAKE_CURRENT_BINARY_DIR}/rosidl_runtime_cpython>
+)
+
+install(TARGETS _raw_buffer
+  DESTINATION "${PYTHON_INSTALL_DIR}/rosidl_runtime_cpython"
+)
+
+# ---------------------------------------------------------------------------
+# Testing
+# ---------------------------------------------------------------------------
+if(BUILD_TESTING)
+  find_package(ament_lint_auto REQUIRED)
+  ament_lint_auto_find_test_dependencies()
+
+  find_package(ament_cmake_pytest REQUIRED)
+  set(_pytest_tests
+    test/rosidl_runtime_cpython/test_dtype.py
+    test/rosidl_runtime_cpython/test_scalar.py
+    test/rosidl_runtime_cpython/test_array.py
+    test/rosidl_runtime_cpython/test_sequence.py
+    test/rosidl_runtime_cpython/test_string.py
+  )
+  foreach(_test_path ${_pytest_tests})
+    get_filename_component(_test_name ${_test_path} NAME_WE)
+    ament_add_pytest_test(${_test_name} ${_test_path}
+      APPEND_ENV PYTHONPATH=${CMAKE_CURRENT_BINARY_DIR}
+      TIMEOUT 60
+    )
+  endforeach()
+endif()
+
+ament_package()
diff --git a/rosidl_runtime_cpython/include/rosidl_runtime_cpython/raw_buffer.h b/rosidl_runtime_cpython/include/rosidl_runtime_cpython/raw_buffer.h
