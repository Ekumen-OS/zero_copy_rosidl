+    assert 'Sequence' in r
+    assert 'Dtype.INT32' in r
+    assert '[1, 2]' in r
+
+
+def test_repr_bounded():
+    s = BoundedSequence(Dtype.INT32, 10)
+    s.append(5)
+    r = repr(s)
+    assert 'BoundedSequence' in r
+    assert '10' in r
