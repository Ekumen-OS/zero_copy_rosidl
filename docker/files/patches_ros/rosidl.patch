+@[  for i, member in enumerate(message.structure.members)]@
+@[    if i]@
+
+@[    end if]@
+  // member: @(member.name)
+  {
+    if (indentation > 0) {
+      out << std::string(indentation, ' ');
+    }
+@[    if isinstance(member.type, BasicType)]@
+    out << "@(member.name): ";
+@[      if member.type.typename in EXPERIMENTAL_CHARACTER_TYPES]@
+    rosidl_generator_traits::character_value_to_yaml(msg.@(member.name).get(), out);
+@[      else]@
+    rosidl_generator_traits::value_to_yaml(msg.@(member.name).get(), out);
+@[      end if]@
+    out << "\n";
+@[    elif isinstance(member.type, (AbstractString, AbstractWString))]@
+    out << "@(member.name): ";
+    rosidl_generator_traits::value_to_yaml(msg.@(member.name), out);
+    out << "\n";
