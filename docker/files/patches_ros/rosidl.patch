+  struct InternalStorage
+  {
+    static constexpr size_t kCapacity =
+      UpperBound > 0 ?
+      ((UpperBound < detail::inline_string_capacity_v<CharT>) ?
+      UpperBound : detail::inline_string_capacity_v<CharT>) :
+      detail::inline_string_capacity_v<CharT>;
