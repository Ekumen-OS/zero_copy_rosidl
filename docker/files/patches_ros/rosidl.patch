+      ELEMENT_TYPE, init, array, (SIZE), element_bound); \
+  } \
+  static inline bool STRUCT_NAME ## __init_with_options( \
+    STRUCT_NAME * array, \
+    size_t element_bound, \
+    const STRUCT_NAME ## __InitOptions * options) \
+  { \
