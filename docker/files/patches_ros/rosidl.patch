+    if (allocator != NULL) { \
+      if (!rcutils_allocator_is_valid(allocator)) { \
+        return false; \
+      } \
+      _string->_impl.allocator = *allocator; \
+    } else { \
+      _string->_impl.allocator = rcutils_get_default_allocator(); \
+    } \
