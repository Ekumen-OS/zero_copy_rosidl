+    if (_string == NULL || (size > 0U && value == NULL)) { \
+      return false; \
+    } \
+    if (!STRUCT_NAME ## __reserve(_string, size)) { \
+      return false; \
+    } \
+    if (size > 0U) { \
+      (void)memcpy(_string->value, value, size * sizeof(CHAR_TYPE)); \
