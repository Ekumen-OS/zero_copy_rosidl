+  ASSERT_TRUE(Traits::assign(&lhs.value->data[1], Traits::world()));
+  ASSERT_TRUE(Array::copy(&lhs, &rhs));
+  EXPECT_TRUE(Array::are_equal(&lhs, &rhs));
