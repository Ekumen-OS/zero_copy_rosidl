+  void swap(BasicString & other) noexcept
+  {
+    using std::swap;
+    swap(storage_pool_, other.storage_pool_);
+    swap(storage_, other.storage_);
+    swap(capacity_, other.capacity_);
+    swap(size_, other.size_);
