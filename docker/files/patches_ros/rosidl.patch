+// ---------------------------------------------------------------------------
+// test_storage_defaults_backed_values:
+//   ExternalStorage for Defaults; default values must be written to backing.
+// ---------------------------------------------------------------------------
+
+static int test_storage_defaults_backed_values(void)
+{
+  // Allocate backing storage for ALL fields
+  bool     b = false;
