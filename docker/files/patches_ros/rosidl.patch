+#ifndef ROSIDL_RUNTIME_C__EXPERIMENTAL__ARRAY_H_
+#define ROSIDL_RUNTIME_C__EXPERIMENTAL__ARRAY_H_
+
+#include <stdbool.h>
+#include <stddef.h>
+#include <stdint.h>
+#include <uchar.h>
