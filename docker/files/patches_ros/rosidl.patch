+
+// Round-trip assign+read for a Scalar<T> field.
+#define ASSERT_SCALAR_ROUNDTRIP(msg, field, val) \
+  do { \
+    (msg).field = (val); \
+    ASSERT_EQ((val), (msg).field); \
+  } while (0)
+
+// ---------------------------------------------------------------------------
+// Empty
