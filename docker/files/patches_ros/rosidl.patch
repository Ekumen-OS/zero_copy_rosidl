+  EXPECT_FALSE(ArrayWrapper<TypeParam>::init(nullptr));
+}
+
+TYPED_TEST(StringArrayTest, fini_null_is_safe)
+{
+  EXPECT_NO_FATAL_FAILURE(ArrayWrapper<TypeParam>::fini(nullptr));
+}
