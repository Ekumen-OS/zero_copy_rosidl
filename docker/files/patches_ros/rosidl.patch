+
+  EXPECT_TRUE(msg->bool_value.value->data);
+  EXPECT_EQ(50u, msg->byte_value.value->data);
+  EXPECT_EQ(-30000, msg->int32_value.value->data);
+  EXPECT_EQ(50000000u, msg->uint64_value.value->data);
+
+  EXP(Defaults__destroy)(msg);
+  return 0;
+}
